# Scaffold smoke-test scratch dir (throwaway: packs + installs the 14 packages into a fresh create-luckystack-app)
.smoke-test/

# Runtime-verification scratch dir + env overlay (throwaway: local Redis/MongoDB bring-up, scaffold matrix, server/client logs)
.runtime-test/
.env.runtime-test

# Framework AI docs bundled INTO create-luckystack-app at build time (generated copy of repo-root CLAUDE.md/docs/skills/.claude/commands — ships in the tarball, never committed)
packages/create-luckystack-app/framework-docs/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

.env
# @luckystack/secret-manager shared bearer token (single-line file, never commit)
.secret-manager-token
node_modules
dist
dist-ssr
*.local
.venv
.cache/
.eslintcache
.lint-unnecessary.out
.lint-packages.out
.ts-errors.out
*.backup

