*.sw?

uploads/*

# Auto-generated types (regenerated on dev server start + postinstall)
apiTypes.generated.ts
apiInputSchemas.generated.ts
apiDocs.generated.json
apiTypeDiagnostics.generated.json
server/prod/generatedApis.ts
server/prod/generatedApis.*.ts
# Catch-all so no future *.generated.* artifact leaks into git.
*.generated.*

# Repomix
repomix-output.xml

# TypeScript Build Artifacts
*.tsbuildinfo

# Test runner machine-readable output (npm run test)
test-results.json

# `luckystack check-env` / `check-i18n` scan reports (hashed logs per run)
dump/

# AI browser-testing artifacts (agent-browser / Playwright / Chrome DevTools MCP)
.agent-browser/
.playwright-mcp/
test-results/
playwright-report/
.claude/settings.local.json
