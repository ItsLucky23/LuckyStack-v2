{
  "name": "lucky-stack-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client": "vite --host",
    "server": "npx tsx server/dev/supervisor.ts",
    "server:direct": "npx tsx server/server.ts",
    "lint": "npm run lint:all",
    "lint:client": "eslint \"src/**/*.{ts,tsx}\" --cache --cache-location .eslintcache --ignore-pattern \"**/*.generated.*\"",
    "lint:server": "eslint \"server/**/*.ts\" \"shared/**/*.ts\" \"config.ts\" --cache --cache-location .eslintcache --ignore-pattern \"**/*.generated.*\" --ignore-pattern \"server/prod/generatedApis.ts\"",
    "lint:all": "npm run lint:client && npm run lint:server",
    "generateArtifacts": "tsx scripts/generateTypeMaps.ts && tsx scripts/generateServerRequests.ts",
    "buildClient": "tsx scripts/generateTypeMaps.ts && tsc -b && vite build",
    "buildServer": "npm run generateArtifacts && node scripts/bundleServer.mjs",
    "build": " npm run generateArtifacts && tsc -b && vite build && node scripts/bundleServer.mjs",
    "prod": "node dist/server.js",
    "production": "node dist/server.js",
    "prisma:format": "prisma format",
    "prisma:validate": "dotenv -e .env.local -- prisma validate",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:db:pull": "dotenv -e .env.local -- prisma db pull",
    "prisma:db:push": "dotenv -e .env.local -- prisma db push",
    "prisma:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "prisma:migrate:reset": "dotenv -e .env.local -- prisma migrate reset",
    "prisma:studio": "dotenv -e .env.local -- prisma studio"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@prisma/client": "^6.19.3",
    "@sentry/node": "^10.48.0",
    "@sentry/react": "^10.48.0",
    "@tailwindcss/postcss": "^4.2.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.540.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "uuid": "^11.1.0",
    "validator": "^13.15.35",
    "vconsole": "^3.15.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-alias": "^5.1.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.5.0",
    "chokidar": "^4.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-dom": "^1.48.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-react-x": "^1.48.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.4"
  }
}
