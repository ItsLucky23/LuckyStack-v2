#!/bin/sh
#? Regenerates docs/AI_QUICK_INDEX.md so it stays in sync with whatever this
#? commit touches (per-package AI_INDEX.md, docs/*.md, slash commands, skills,
#? new packages). The generator is deterministic (no timestamps), so when
#? nothing relevant changed the resulting file is byte-identical and the
#? `git add` below is a no-op for the working tree.
#?
#? Active via `git config core.hooksPath .githooks` (set by the root
#? `prepare` script at install time).

set -e

if ! command -v npm >/dev/null 2>&1; then
  echo "[pre-commit] npm not on PATH — skipping ai:index regeneration."
  exit 0
fi

echo "[pre-commit] Regenerating docs/AI_QUICK_INDEX.md..."
npm run ai:index --silent

git add docs/AI_QUICK_INDEX.md
