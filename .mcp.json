{
  "mcpServers": {
    "luckystack": {
      "type": "stdio",
      "command": "node",
      "args": ["packages/mcp/dist/index.js"]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    }
  }
}
