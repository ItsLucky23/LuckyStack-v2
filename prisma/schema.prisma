// ============================================
// PRISMA CLI COMMANDS REFERENCE
// ============================================
// npm run prisma:format       - Auto-format schema file
// npm run prisma:validate     - Validate schema syntax
// npm run prisma:generate     - Generate Prisma Client
// npm run prisma:db:pull      - Sync schema from existing database
// npm run prisma:db:push      - Push schema to database (dev only)
// npm run prisma:migrate:dev  - Create and apply migration
// npm run prisma:migrate:reset- Reset database and reapply migrations
// npm run prisma:studio       - Open database GUI
// ============================================

generator client {
  provider = "prisma-client-js"
}

// --- MYSQL (Default) ---
// datasource db {
//   provider = "mysql"
//   url      = env("DATABASE_URL")
// }

// --- POSTGRESQL ---
// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

// --- MONGODB ---
// Note: MongoDB requires different schema syntax (see model comments below)
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --- SQLITE (Development only - no server needed) ---
// datasource db {
//   provider = "sqlite"
//   url      = "file:./dev.db"
// }

// ============================================
// USER MODEL
// ============================================
// This is the default user model. Extend as needed.
// 
// Database-specific syntax differences:
// 
// MySQL/PostgreSQL:
//   id        String  @id @default(uuid())
//   avatar    String  @db.VarChar(512)
// 
// MongoDB:
//   id        String  @id @default(uuid()) @map("_id")
//   avatar    String
// 
// SQLite:  
//   id        String  @id @default(uuid())
//   avatar    String  // No @db.VarChar for SQLite
// ============================================

model User {
  id             String    @id @default(uuid()) @map("_id")
  email          String
  name           String
  password       String?
  admin          Boolean   @default(false)
  avatar         String    @default("")
  avatarFallback String    @default("")
  language       LANGUAGE  @default(en)
  theme          THEME     @default(dark)
  provider       PROVIDERS
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("users")
}

enum THEME {
  dark
  light
}

enum LANGUAGE {
  nl
  en
  de
  fr
}

enum PROVIDERS {
  credentials
  google
  github
  x
  facebook
  linkedIn
  apple
  discord
  instagram
}
