{
  "name": "@luckystack/login",
  "version": "0.4.1",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "Authentication for LuckyStack: credentials + OAuth (Google/GitHub/Facebook/Discord), Redis-backed sessions, single-session enforcement, lifecycle hooks. Pairs with @luckystack/core.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/login"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/login#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "authentication",
    "oauth",
    "session",
    "login",
    "register",
    "credentials",
    "redis",
    "prisma"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.4.1",
    "bcryptjs": "^3.0.0",
    "dotenv": "^17.0.0",
    "validator": "^13.15.35"
  },
  "peerDependencies": {
    "@prisma/client": "^6.19.0",
    "socket.io": "^4.8.0",
    "@luckystack/email": "^0.4.1"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    },
    "@luckystack/email": {
      "optional": true
    }
  }
}
