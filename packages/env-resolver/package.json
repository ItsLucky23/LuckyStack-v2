{
  "name": "@luckystack/env-resolver",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Resolve `process.env` from a remote env server (with versioning + git-checkable config) instead of dotenv files. Falls back to local `.env` when remote is unreachable or when source is 'local'.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/env-resolver"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/master/packages/env-resolver#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "env",
    "environment",
    "dotenv",
    "remote-config",
    "versioning",
    "secrets"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch"
  },
  "dependencies": {
    "@luckystack/core": "^0.1.0"
  }
}
