{
  "name": "@luckystack/test-runner",
  "version": "0.6.4",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "Generated-type-driven test layers for LuckyStack: contract smoke (Zod-valid input), auth enforcement, rate-limit, and crash-resistance fuzz. Walks every endpoint via the generated apiMethodMap.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/test-runner"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/test-runner#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "testing",
    "contract-testing",
    "fuzz",
    "rate-limit",
    "api-testing",
    "auth-testing",
    "zod"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.6.4"
  },
  "peerDependencies": {
    "@luckystack/login": "^0.6.4",
    "socket.io-client": "^4.8.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@luckystack/login": {
      "optional": true
    }
  }
}
