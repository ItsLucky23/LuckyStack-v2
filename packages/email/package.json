{
  "name": "@luckystack/email",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Pluggable transactional email for LuckyStack: Console (dev), Resend, and SMTP adapters with a registry-based plug-in pattern. Optional dep — install only when forgotPassword='framework' or you want to send transactional mail.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/email"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/master/packages/email#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "email",
    "transactional",
    "resend",
    "smtp",
    "nodemailer"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.1.0"
  },
  "peerDependencies": {
    "resend": "^6.0.0",
    "nodemailer": "^6.9.0"
  },
  "peerDependenciesMeta": {
    "resend": { "optional": true },
    "nodemailer": { "optional": true }
  }
}
