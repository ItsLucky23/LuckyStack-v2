{
  "name": "@luckystack/api",
  "version": "0.1.4",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Type-safe API request handlers for LuckyStack. WebSocket-first via socket.io, with HTTP fallback. File-based routing, generated route map, integrated rate limiting, validation, hooks, and error-tracking tracing.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/api"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/master/packages/api#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "api",
    "socket.io",
    "websocket",
    "http",
    "realtime",
    "typescript",
    "framework",
    "rate-limiting",
    "validation"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.1.4",
    "@luckystack/login": "^0.1.4",
    "@luckystack/error-tracking": "^0.1.4"
  },
  "peerDependencies": {
    "@prisma/client": "^6.19.0",
    "socket.io": "^4.8.0"
  }
}
