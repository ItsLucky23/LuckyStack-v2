{
  "name": "@luckystack/mcp",
  "version": "0.2.6",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "Read-only MCP server that exposes a LuckyStack project's committed AI context (decisions, dependency graph, routes, runbooks, capabilities) to Claude Code as queryable tools.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/mcp#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "mcp",
    "claude",
    "ai",
    "context"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "luckystack-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  }
}
