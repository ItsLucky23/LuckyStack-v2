{
  "name": "@luckystack/server",
  "version": "0.4.1",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "One-call server bootstrap for LuckyStack: HTTP + Socket.io + framework routes (api, sync, _health, /auth, uploads) wired together. Consumer's server.ts shrinks to ~20 lines.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "server",
    "bootstrap",
    "socket.io",
    "http",
    "framework",
    "fullstack"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parseArgv": {
      "types": "./dist/parseArgv.d.ts",
      "import": "./dist/parseArgv.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/api": "^0.4.1",
    "@luckystack/core": "^0.4.1"
  },
  "peerDependencies": {
    "@prisma/client": "^6.19.0",
    "socket.io": "^4.8.0",
    "@luckystack/devkit": "^0.4.1",
    "@luckystack/docs-ui": "^0.4.1",
    "@luckystack/email": "^0.4.1",
    "@luckystack/error-tracking": "^0.4.1",
    "@luckystack/login": "^0.4.1",
    "@luckystack/presence": "^0.4.1",
    "@luckystack/sync": "^0.4.1"
  },
  "peerDependenciesMeta": {
    "@luckystack/devkit": {
      "optional": true
    },
    "@luckystack/docs-ui": {
      "optional": true
    },
    "@luckystack/email": {
      "optional": true
    },
    "@luckystack/error-tracking": {
      "optional": true
    },
    "@luckystack/login": {
      "optional": true
    },
    "@luckystack/presence": {
      "optional": true
    },
    "@luckystack/sync": {
      "optional": true
    }
  }
}
