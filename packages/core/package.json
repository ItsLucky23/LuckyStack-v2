{
  "name": "@luckystack/core",
  "version": "0.1.5",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "LuckyStack core: socket-first transport contracts, Redis adapter, project-config registry, hooks registry, response normalization, rate limiting, and shared session types. Foundation for every other @luckystack/* package.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/master/packages/core#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "socket.io",
    "realtime",
    "framework",
    "fullstack",
    "prisma",
    "typescript",
    "redis",
    "react",
    "nodejs"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js"
    },
    "./typemap": {
      "types": "./dist/apiTypeStubs.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "dotenv": "^17.0.0"
  },
  "peerDependencies": {
    "@prisma/client": "^6.19.0",
    "eslint": "^9.0.0",
    "ioredis": "^5.10.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.0.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "sonner": "^2.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    },
    "sonner": {
      "optional": true
    }
  }
}
