    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "cli",
    "scaffold",
    "add",
    "generator"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "luckystack": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "assets",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "scripts": {
