{
  "name": "@luckystack/error-tracking",
  "version": "0.3.0",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "Optional error-tracking integration for LuckyStack (currently Sentry-backed). Auto-wires error/performance capture into the framework's hook surface and request transports. No-op when DSN is missing.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/error-tracking"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/error-tracking#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "error-tracking",
    "sentry",
    "observability",
    "monitoring",
    "tracing",
    "apm"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.3.0"
  },
  "devDependencies": {
    "@luckystack/login": "^0.3.0"
  },
  "peerDependencies": {
    "@sentry/node": "^10.48.0",
    "dd-trace": "^5.0.0",
    "hot-shots": "^10.0.0",
    "posthog-node": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@sentry/node": {
      "optional": true
    },
    "dd-trace": {
      "optional": true
    },
    "hot-shots": {
      "optional": true
    },
    "posthog-node": {
      "optional": true
    }
  }
}
