// Prisma schema — recommended User model for LuckyStack's `defaultPrismaUserAdapter`.
// If your app's User model deviates, call `registerUserAdapter()` in
// `luckystack/server/index.ts` with a custom adapter instead of editing the framework.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Set during scaffold via `npx create-luckystack-app` interactive prompts.
  // To switch providers later, edit `provider` here and update DATABASE_URL.
  provider = "{{DB_PROVIDER}}"
  url      = env("DATABASE_URL")
}

enum LANGUAGE {
  en
  nl
  de
  fr
}

enum THEME {
  light
  dark
}

enum PROVIDERS {
  credentials
  google
  github
  discord
  facebook
  microsoft
}

model User {
  id              String    {{USER_ID_ATTRS}}
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  email           String
  password        String?
  provider        PROVIDERS @default(credentials)

  name            String?
  avatar          String    @default("")
  avatarFallback  String    @default("")
  admin           Boolean   @default(false)

  language        LANGUAGE  @default(en)
  theme           THEME     @default(light)

  //? Free-form per-user settings (notification opt-ins, etc.). Read/written by
  //? the settings/updatePreferences route and surfaced on the session.
  preferences     Json?

  //? 2FA (ADR 0024) — all optional so existing databases keep working; the
  //? framework only writes them once a user enrolls via /auth/api/2fa/setup.
  //? totpSecret is encrypted at rest when TOTP_ENCRYPTION_KEY is set and is
  //? NEVER sent to the client (sanitized by @luckystack/login). recoveryCodes
  //? holds sha256 hashes of the unused one-time backup codes.
  twoFactorEnabled Boolean  @default(false)
  totpSecret      String?
  recoveryCodes   Json?

  @@unique([email, provider])
}
