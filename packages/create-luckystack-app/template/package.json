{
  "name": "{{PROJECT_NAME}}",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "client": "vite --host 0.0.0.0",
    "client:port": "vite --host 0.0.0.0 --port",
    "server": "luckystack-dev",
    "server:once": "tsx --tsconfig tsconfig.server.json server/server.ts",
    "build": "vite build && node scripts/bundleServer.mjs",
    "prod": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" --cache --cache-location .eslintcache --ignore-pattern \"**/*.generated.*\" --ignore-pattern \"server/prod/**\"",
    "typecheck": "tsc --noEmit",
    "ai:capabilities": "node scripts/generateAiCapabilities.mjs",
    "ai:project-index": "node scripts/generateProjectIndex.mjs",
    "ai:decisions": "node scripts/generateDecisionsIndex.mjs",
    "ai:lessons": "node scripts/generateLessonsIndex.mjs",
    "ai:examples": "node scripts/generateExamplesIndex.mjs",
    "ai:runbooks": "node scripts/generateRunbooks.mjs",
    "ai:product": "node scripts/generateProductOverview.mjs",
    "ai:graph": "node scripts/generateGraph.mjs",
    "ai:context-budget": "node scripts/generateContextBudget.mjs",
    "ai:lint": "node scripts/lintInvariants.mjs",
    "ai:doc-staleness": "node scripts/checkDocStaleness.mjs",
    "ai:eval": "node eval/scoreEval.mjs",
    "generateArtifacts": "tsx --tsconfig tsconfig.server.json scripts/generateTypeMaps.ts && tsx --tsconfig tsconfig.server.json scripts/generateServerRequests.ts",
    "test": "npm run generateArtifacts && tsx --tsconfig tsconfig.server.json scripts/testAll.ts",
    "scaffold:test": "node scripts/scaffoldRouteTest.mjs",
    "scaffold:page": "node scripts/scaffoldPage.mjs",
    "test:e2e": "playwright test",
    "prisma:generate": "tsx --tsconfig tsconfig.server.json scripts/prismaWithSecrets.ts generate",
    "prisma:db:push": "tsx --tsconfig tsconfig.server.json scripts/prismaWithSecrets.ts db push",
    "prisma:migrate:dev": "tsx --tsconfig tsconfig.server.json scripts/prismaWithSecrets.ts migrate dev",
    "help": "node scripts/help.mjs"
  },
  "dependencies": {
    "@luckystack/api": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/core": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/login": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/presence": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/error-tracking": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/server": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/sync": "^{{LUCKYSTACK_VERSION}}",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.0",
    "dotenv": "^16.6.1",
    "ioredis": "^5.10.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "uuid": "^14.0.0",
    "validator": "^13.15.35",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@luckystack/cli": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/devkit": "^{{LUCKYSTACK_VERSION}}",
    "@luckystack/test-runner": "^{{LUCKYSTACK_VERSION}}",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-react-x": "^1.48.4",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^15.15.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
