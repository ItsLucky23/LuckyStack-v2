{
  "name": "@luckystack/sync",
  "version": "0.2.5",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "Real-time sync transport for LuckyStack: type-safe room-based fanout, server + per-client validation, streaming, optimistic offline queue. Server entry plus a browser-safe ./client subpath.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/sync"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/sync#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "sync",
    "realtime",
    "socket.io",
    "websocket",
    "react",
    "multiplayer",
    "fanout",
    "rooms",
    "framework"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.2.5",
    "@luckystack/error-tracking": "^0.2.5"
  },
  "peerDependencies": {
    "@prisma/client": "^6.19.0",
    "react": "^19.2.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
