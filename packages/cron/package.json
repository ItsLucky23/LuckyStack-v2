{
  "name": "@luckystack/cron",
  "version": "0.7.2",
  "private": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "description": "Leader-elected, Redis-backed cron scheduler for LuckyStack: declarative recurring jobs that run on exactly one instance, with overlap guards, jitter, per-tenant fan-out, and run stats.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/cron"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/main/packages/cron#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "cron",
    "scheduler",
    "jobs",
    "leader-election",
    "redis"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@luckystack/core": "^0.7.2",
    "croner": "^9.0.0"
  }
}
