{
  "name": "@luckystack/presence",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "description": "Presence and activity awareness for LuckyStack: AFK detection, room-peer notifications, lifecycle (connect / disconnect / reconnect), single-session enforcement integration. For multiplayer and collaborative apps.",
  "license": "MIT",
  "author": "Mathijs van Melick <mathijsvanmelick3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ItsLucky23/LuckyStack-v2.git",
    "directory": "packages/presence"
  },
  "homepage": "https://github.com/ItsLucky23/LuckyStack-v2/tree/master/packages/presence#readme",
  "bugs": {
    "url": "https://github.com/ItsLucky23/LuckyStack-v2/issues"
  },
  "keywords": [
    "luckystack",
    "presence",
    "awareness",
    "multiplayer",
    "collaboration",
    "socket.io",
    "afk",
    "realtime",
    "rooms"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "docs",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch"
  },
  "dependencies": {
    "@luckystack/core": "^0.1.0",
    "@luckystack/login": "^0.1.0"
  },
  "peerDependencies": {
    "socket.io": "^4.8.0",
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "socket.io": {
      "optional": true
    }
  }
}
