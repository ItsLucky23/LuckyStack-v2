{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "module": "ES2022", /* Server uses ES2022 modules specifically */
    "moduleResolution": "bundler", /* Modern resolver for ESM + esbuild bundling */
    "outDir": "dist/server", /* Redirect output structure to the directory. */
    "incremental": true,
    "tsBuildInfoFile": "./.cache/tsbuild/server.tsbuildinfo",
    "types": [
      "node"
    ], /* Type declaration files to be included in compilation. */
    "sourceMap": true, /* Generates corresponding '.map' file. */
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "src/*": [
        "./src/*"
      ],
      "config": [
        "./config.ts"
      ],
      "shared/*": [
        "./shared/*"
      ],
      "@luckystack/core": [
        "./packages/core/src/index.ts"
      ],
      "@luckystack/core/config": [
        "./packages/core/src/config.ts"
      ],
      "@luckystack/core/client": [
        "./packages/core/src/client.ts"
      ],
      "@luckystack/core/typemap": [
        "./packages/core/src/apiTypeStubs.ts"
      ],
      "@luckystack/sync/client": [
        "./packages/sync/src/client.ts"
      ],
      "@luckystack/login": [
        "./packages/login/src/index.ts"
      ],
      "@luckystack/sync": [
        "./packages/sync/src/index.ts"
      ],
      "@luckystack/error-tracking": [
        "./packages/error-tracking/src/index.ts"
      ],
      "@luckystack/api": [
        "./packages/api/src/index.ts"
      ],
      "@luckystack/devkit": [
        "./packages/devkit/src/index.ts"
      ],
      "@luckystack/email": [
        "./packages/email/src/index.ts"
      ],
      "@luckystack/presence": [
        "./packages/presence/src/index.ts"
      ],
      "@luckystack/cron": [
        "./packages/cron/src/index.ts"
      ],
      "@luckystack/presence/client": [
        "./packages/presence/src/client/index.ts"
      ],
      "@luckystack/router": [
        "./packages/router/src/index.ts"
      ],
      "@luckystack/test-runner": [
        "./packages/test-runner/src/index.ts"
      ],
      "@luckystack/server": [
        "./packages/server/src/index.ts"
      ],
      "@luckystack/secret-manager": [
        "./packages/secret-manager/src/index.ts"
      ]
    },
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ],
  },
  "include": [
    "vite.config.ts",
    "config.ts",
    "scripts/prismaWithSecrets.ts",
    "scripts/verifyOrmWireProjection.ts",
    "server/**/*",
    "shared/**/*",
    "packages/core/src/**/*",
    "packages/login/src/**/*",
    "packages/sync/src/**/*",
    "packages/error-tracking/src/**/*",
    "packages/api/src/**/*",
    "packages/devkit/src/**/*",
    "packages/email/src/**/*",
    "packages/presence/src/**/*",
    "packages/cron/src/**/*",
    "packages/router/src/**/*",
    "packages/server/src/**/*",
    "packages/test-runner/src/**/*",
    "packages/create-luckystack-app/src/**/*",
    "packages/cli/src/**/*",
    "packages/docs-ui/src/**/*",
    "packages/secret-manager/src/**/*",
    "packages/mcp/src/**/*",
    "src/**/_api/**/*",
    "src/**/_sync/**/*",
    "src/**/_server/**/*",
    "src/**/*_server.ts",
    "src/**/*_server.tsx",
    "src/**/*_server.js",
    "src/**/*_server.jsx"
  ],
  "exclude": [
    "packages/core/src/apiRequest.ts",
    "packages/core/src/client.ts",
    "packages/core/src/react/**/*",
    "packages/sync/src/syncRequest.ts",
    "packages/sync/src/client.ts",
    "packages/presence/src/client/**/*",
    "packages/devkit/src/templates/page_*.template.tsx"
  ]
}