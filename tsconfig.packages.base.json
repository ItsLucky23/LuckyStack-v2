{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    //? TS 6 no longer auto-includes every visible `@types/*` the way 5.7 did, so
    //? declare the ambient type packages the package builds rely on: `node` for
    //? the server-side built-ins and `react`/`react-dom` for the `/client` subpaths.
    "types": ["node", "react", "react-dom"]
  }
}
