# This file is the template for .env.local.
# Put real secrets here; .env.local overrides .env.
#
# Sections mirror .env_template — see there for full per-key documentation.
# Only keys that carry a real secret value live here; pure config knobs stay in .env.

# ============================================
# === @luckystack/core (required) ===
# ============================================

REDIS_PASSWORD=

# ============================================
# === @luckystack/login (Optional OAuth providers) ===
# ============================================
# Fill in ONLY the providers you actually use on /login. Each block is independent.

# --- Google ---
GOOGLE_CLIENT_ID=xxxxx
GOOGLE_CLIENT_SECRET=xxxxx
DEV_GOOGLE_CLIENT_ID=xxxxx
DEV_GOOGLE_CLIENT_SECRET=xxxxx

# --- GitHub ---
GITHUB_CLIENT_ID=xxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxx
DEV_GITHUB_CLIENT_ID=xxxxx
DEV_GITHUB_CLIENT_SECRET=xxxxx

# --- Facebook ---
FACEBOOK_CLIENT_ID=xxxxxxx
FACEBOOK_CLIENT_SECRET=xxxxxxx
DEV_FACEBOOK_CLIENT_ID=xxxxx
DEV_FACEBOOK_CLIENT_SECRET=xxxxx

# --- Discord ---
DISCORD_CLIENT_ID=xxxxxxx
DISCORD_CLIENT_SECRET=xxxxxxx
DEV_DISCORD_CLIENT_ID=xxxxx
DEV_DISCORD_CLIENT_SECRET=xxxxx

# --- Microsoft (Azure AD) ---
MICROSOFT_CLIENT_ID=xxxxxxx
MICROSOFT_CLIENT_SECRET=xxxxxxx
DEV_MICROSOFT_CLIENT_ID=xxxxx
DEV_MICROSOFT_CLIENT_SECRET=xxxxx
# Optional: 'common' for any tenant, UUID to lock to a single Azure AD tenant.
MICROSOFT_TENANT_ID=common

# ============================================
# === Database (Prisma, required) ===
# ============================================

# --- MONGODB ---
DATABASE_URL="mongodb://root:password@localhost:27017/databaseName?authSource=admin&replicaSet=rs0"

# ============================================
# === @luckystack/email (Optional) ===
# ============================================
# Pick ONE: either fill in RESEND_API_KEY, OR fill in the SMTP_* block.
# Leave both empty to fall back to ConsoleSender (logs the reset link to the
# terminal instead of sending it). See .env_template for the full explanation.

EMAIL_FROM=onboarding@resend.dev

# OPTION A: Resend
RESEND_API_KEY=

# OPTION B: SMTP (Mailtrap / Gmail SMTP / own server). SECURE=true for port 465.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ============================================
# === @luckystack/error-tracking (Optional) ===
# ============================================

SENTRY_DSN=
SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENABLED=false

# ============================================
# === Test script secrets (Optional, scripts/test*.ts) ===
# ============================================
# Only needed if you actually run those scripts against a server that locks down
# /_test/reset or uses bearer-token auth. The non-secret TEST_* knobs live in
# .env_template.

TEST_RESET_TOKEN=
TEST_AUTH_TOKEN=
