{
  "extends": "./tsconfig.shared.json",
  "compilerOptions": {
    "target": "ES2022", /* Override base target for broader browser support */
    "useDefineForClassFields": true, /* Emit class fields with Define semantics. */
    "lib": [
      "ES2023",
      "DOM",
      "DOM.Iterable"
    ], /* Include DOM libraries for frontend code */
    /* Bundler mode */
    "moduleResolution": "bundler", /* optimal for bundlers like Vite */
    "allowImportingTsExtensions": true, /* Allow imports to include TypeScript file extensions. */
    "isolatedModules": true, /* Ensure that each file can be safely transpiled without relying on other imports. */
    "moduleDetection": "force", /* Force module detection for non-module files. */
    "noEmit": true, /* Do not emit outputs (Vite handles this). */
    "incremental": true,
    "tsBuildInfoFile": "./.cache/tsbuild/client.tsbuildinfo",
    "jsx": "react-jsx", /* Specify what JSX code is generated. */
    "allowJs": true, /* Allow JavaScript files to be a part of your program. */
    "checkJs": false, /* Enable error reporting in type-checked JavaScript files. */
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "src/*": [
        "./src/*"
      ],
      "config": [
        "./config.ts"
      ],
      "shared/*": [
        "./shared/*"
      ],
      "@luckystack/core": [
        "./packages/core/src/index.ts"
      ],
      "@luckystack/login": [
        "./packages/login/src/index.ts"
      ],
      "@luckystack/sync": [
        "./packages/sync/src/index.ts"
      ],
      "@luckystack/sentry": [
        "./packages/sentry/src/index.ts"
      ],
      "@luckystack/api": [
        "./packages/api/src/index.ts"
      ],
      "@luckystack/devkit": [
        "./packages/devkit/src/index.ts"
      ],
      "@luckystack/presence": [
        "./packages/presence/src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "shared",
    "packages/core/src",
    "packages/login/src",
    "packages/sync/src",
    "packages/sentry/src",
    "packages/api/src",
    "packages/devkit/src",
    "packages/presence/src"
  ],
  "exclude": [
    "src/**/_api/**",
    "src/**/_sync/**",
    "src/**/server/**",
    "src/**/_server/**",
    "src/**/*_server.ts",
    "src/**/*_server.tsx",
    "src/**/*_server.js",
    "src/**/*_server.jsx"
  ]
}
